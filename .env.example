X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# YouTube Data API
YOUTUBE_API_KEY=

# Easein Shopify
SHOPIFY_API_KEY=
SHOPIFY_STORE_URL=easein-6053.myshopify.com

# DMPtech.ai (internal services)
DMPTECH_API_KEY=
